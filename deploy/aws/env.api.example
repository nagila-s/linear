# Variáveis para o serviço da API (ECS / App Runner / EC2).
# Use os mesmos valores do worker, exceto onde indicado.

APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# Domínio da Vercel (ajuste após o deploy do site)
CORS_ORIGINS=https://seu-app.vercel.app

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_DSN=

BUCKET_PDF=pdf
BUCKET_PAGES=pages
BUCKET_FIGURES=figures
BUCKET_JSON=json

OPENAI_API_KEY=
OPENAI_MODEL_LINEARIZATION=gpt-5.2-pro
OPENAI_MODEL_CONTEXT=gpt-5.2-pro
OPENAI_PREFER_RESPONSES_API=true
LINEARIZATION_PROMPT_FILE=prompt.txt
LINEAR_PIPELINE_ONLY=true
PDF_RENDER_DPI=150
LINEARIZE_PAGE_CONCURRENCY=4

# API e worker em hosts diferentes: PDF tem de ir para o Supabase (não use cache local)
PDF_STORAGE_STRATEGY=supabase
PDF_MAX_SIZE_MB=1024
PROCESS_VERSION_STRATEGY=lin-{linear_prompt_version}

# Não precisa na API (só no worker), mas não atrapalha se vier copiado:
# WORKER_POLL_SECONDS=5
