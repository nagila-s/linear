{
  "family": "linear-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::089200327380:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::089200327380:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "linear-worker",
      "image": "089200327380.dkr.ecr.us-east-2.amazonaws.com/linear-worker:latest",
      "essential": true,
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "PDF_STORAGE_STRATEGY", "value": "supabase" },
        { "name": "WORKER_POLL_SECONDS", "value": "5" },
        { "name": "WORKER_MAX_ATTEMPTS", "value": "3" },
        { "name": "BUCKET_PDF", "value": "pdf" },
        { "name": "BUCKET_PAGES", "value": "pages" },
        { "name": "BUCKET_FIGURES", "value": "figures" },
        { "name": "BUCKET_JSON", "value": "json" },
        { "name": "DORINA_API_KEY_HEADER", "value": "Authorization" },
        { "name": "DORINA_BRAILLE", "value": "true" },
        { "name": "OPENAI_MODEL_LINEARIZATION", "value": "gpt-5.2" },
        { "name": "OPENAI_MODEL_CONTEXT", "value": "gpt-5.2" },
        { "name": "PDF_RENDER_DPI", "value": "120" },
        { "name": "LINEARIZATION_PROMPT_FILE", "value": "prompt.txt" },
        { "name": "LINEAR_PIPELINE_ONLY", "value": "true" },
        { "name": "LINEARIZE_PAGE_CONCURRENCY", "value": "4" }
      ],
      "secrets": [
        { "name": "SUPABASE_URL", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/SUPABASE_URL" },
        { "name": "SUPABASE_SERVICE_ROLE_KEY", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/SUPABASE_SERVICE_ROLE_KEY" },
        { "name": "SUPABASE_DB_DSN", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/SUPABASE_DB_DSN" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/OPENAI_API_KEY" },
        { "name": "DORINA_API_URL", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/DORINA_API_URL" },
        { "name": "DORINA_API_KEY", "valueFrom": "arn:aws:ssm:us-east-2:089200327380:parameter/linear/DORINA_API_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linear-worker",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ]
}
