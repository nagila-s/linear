# Variaveis para o servico ECS linear-worker (sem porta HTTP).

APP_ENV=production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_DSN=

BUCKET_PDF=pdf
BUCKET_PAGES=pages
BUCKET_FIGURES=figures
BUCKET_JSON=json

OPENAI_API_KEY=
OPENAI_MODEL_LINEARIZATION=gpt-5.2-pro
OPENAI_MODEL_CONTEXT=gpt-5.2-pro
OPENAI_PREFER_RESPONSES_API=true
LINEARIZATION_PROMPT_FILE=prompt.txt
LINEAR_PIPELINE_ONLY=true
PDF_RENDER_DPI=150
LINEARIZE_PAGE_CONCURRENCY=4

PDF_STORAGE_STRATEGY=supabase
PDF_MAX_SIZE_MB=1024
PROCESS_VERSION_STRATEGY=lin-{linear_prompt_version}

WORKER_POLL_SECONDS=5
WORKER_MAX_ATTEMPTS=3
WORKER_STALE_JOB_MINUTES=120

DORINA_API_URL=
DORINA_API_KEY=
DORINA_API_KEY_HEADER=Authorization
DORINA_DOCUMENT_TYPE=string
DORINA_BRAILLE=false
DORINA_SIGNED_URL_EXPIRES_SECONDS=3600
DORINA_TIMEOUT_SECONDS=60
